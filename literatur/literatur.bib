@online{ettingerEnterpriseArchitectureDynamic2025,
  title = {Enterprise {{Architecture}} as a {{Dynamic Capability}} for {{Scalable}} and {{Sustainable Generative AI}} Adoption: {{Bridging Innovation}} and {{Governance}} in {{Large Organisations}}},
  shorttitle = {Enterprise {{Architecture}} as a {{Dynamic Capability}} for {{Scalable}} and {{Sustainable Generative AI}} Adoption},
  author = {Ettinger, Alexander},
  date = {2025-05-09},
  eprint = {2505.06326},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2505.06326},
  url = {http://arxiv.org/abs/2505.06326},
  urldate = {2026-03-10},
  abstract = {Generative Artificial Intelligence is a powerful new technology with the potential to boost innovation and reshape governance in many industries. Nevertheless, organisations face major challenges in scaling GenAI, including technology complexity, governance gaps and resource misalignments. This study explores how Enterprise Architecture Management can meet the complex requirements of GenAI adoption within large enterprises. Based on a systematic literature review and the qualitative analysis of 16 semi-structured interviews with experts, it examines the relationships between EAM, dynamic capabilities and GenAI adoption. The review identified key limitations in existing EA frameworks, particularly their inability to fully address the unique requirements of GenAI. The interviews, analysed using the Gioia methodology, revealed critical enablers and barriers to GenAI adoption across industries. The findings indicate that EAM, when theorised as sensing, seizing and transforming dynamic capabilities, can enhance GenAI adoption by improving strategic alignment, governance frameworks and organisational agility. However, the study also highlights the need to tailor EA frameworks to GenAI-specific challenges, including low data governance maturity and the balance between innovation and compliance. Several conceptual frameworks are proposed to guide EA leaders in aligning GenAI maturity with organisational readiness. The work contributes to academic understanding and industry practice by clarifying the role of EA in bridging innovation and governance in disruptive technology environments.},
  pubstate = {prepublished},
  keywords = {Computer Science - Artificial Intelligence,Computer Science - Computers and Society},
  file = {C\:\\Users\\Julian\\Zotero\\storage\\3WBGT238\\Ettinger - 2025 - Enterprise Architecture as a Dynamic Capability for Scalable and Sustainable Generative AI adoption.pdf;C\:\\Users\\Julian\\Zotero\\storage\\VV2GNZ9G\\2505.html}
}

@article{ghazalSparseMixtureofExpertsTransformers2026,
  title = {Sparse {{Mixture-of-Experts Transformers}} for {{Efficient Scaling}} of {{Large Language Models}}},
  author = {Ghazal, Taher M.},
  date = {2026},
  journaltitle = {Procedia Computer Science},
  shortjournal = {Procedia Computer Science},
  volume = {275},
  pages = {923--930},
  issn = {18770509},
  doi = {10.1016/j.procs.2026.01.105},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S1877050926001067},
  urldate = {2026-04-26},
  abstract = {Large Language Models (LLMs) are the best at processing natural language. Due to their growing size and computing needs, scalability, efficiency, and deployment are difficult. Traditional dense transformer designs activate all parameters during inference, increasing power consumption, delay, and cost. The biggest challenge is scaling LLMs without compromising performance, interpretability, or generalizability. Current compression and parameter-sharing methods fail to balance efficiency and accuracy in large-scale deployments, despite slight advantages. Sparse Mixture-of-Experts Transformers (SMOE-T) are a novel paradigm for large-scale language modeling that uses conditional computation to improve efficiency. Sparse gating activates only select expert modules for each input, saving computational power without compromising model expressiveness in SMoE-T. The approach allows experts to specialize in specific languages or subjects, increasing productivity and flexibility. On common NLP datasets for language modeling, machine translation, and question answering, SMoE-T outperforms dense transformers in accuracy and reduces FLOPs and inference latency by 60\%. SMoE-T is scalable, making it easy to train and deploy in distributed systems. Finally, SMoE-T allows resource-efficient and scalable LLM training and deployment, enabling long-term, widely available generative AI solutions.},
  langid = {english},
  keywords = {_peer-reviewed},
  file = {C:\Users\Julian\Zotero\storage\6BRJPBYY\Ghazal - 2026 - Sparse Mixture-of-Experts Transformers for Efficient Scaling of Large Language Models.pdf}
}

@inproceedings{hosseiniImprovingLLMRetrieval2025,
  title = {Improving {{LLM Retrieval}} with {{GraphRAG-SF}}: {{Semantic Filtering}} for {{Graph-Based RAG Systems}}},
  shorttitle = {Improving {{LLM Retrieval}} with {{GraphRAG-SF}}},
  booktitle = {2025 {{IEEE International Conference}} on {{Big Data}} ({{BigData}})},
  author = {Hosseini, Mohammad-Parsa and Shah, Ankit and Miao, Connie and Wei, Wei},
  date = {2025-12-08},
  pages = {2561--2568},
  publisher = {IEEE},
  location = {Macau, China},
  doi = {10.1109/BigData66926.2025.11401790},
  url = {https://ieeexplore.ieee.org/document/11401790/},
  urldate = {2026-04-26},
  abstract = {Retrieval-Augmented Generation (RAG) enhances Large Language Models (LLMs) by grounding them in external knowledge, but graph-based RAG systems remain vulnerable to retrieval noise that inflates token costs and degrades answer quality. To address this, we introduce GraphRAG-SF, a lightweight extension to GraphRAG that incorporates a twostage refinement pipeline combining Multi-Objective Node Scoring with Semantic Filtering. The scoring mechanism evaluates semantic similarity, graph centrality, and edge coherence to retain structurally important and contextually aligned nodes, while a query-adaptive filtering stage removes noisy nodes directly in the embedding space, producing leaner and more relevant subgraphs without retraining. Experiments on a public benchmark show that GraphRAG-SF outperforms GraphRAG across answer quality (Exact Match +0.14, F1 +0.05) and retrieval metrics (Hit@1, Precision@1, Recall@1, and MRR@1 all +0.14). Qualitative evaluations also demonstrate improvements in correctness (+0.06) and faithfulness (+0.10), with comparable completeness, highlighting the benefits of early-stage pruning. Designed for deployment readiness, GraphRAG-SF integrates seamlessly into enterprise retrieval frameworks and supports configurable thresholds, pluggable encoders, and flexible cloud or on-premise environments. Overall, GraphRAG-SF shows that early, query-aware semantic filtering is essential for building efficient, robust, and production-ready LLM reasoning systems.},
  eventtitle = {2025 {{IEEE International Conference}} on {{Big Data}} ({{BigData}})},
  isbn = {979-8-3315-9447-3},
  langid = {english},
  keywords = {_peer-reviewed},
  file = {C:\Users\Julian\Zotero\storage\HI79LLU4\Hosseini et al. - 2025 - Improving LLM Retrieval with GraphRAG-SF Semantic Filtering for Graph-Based RAG Systems.pdf}
